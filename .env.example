# Copy to .env and fill in. NEVER commit .env (gitignored).

# --- OpenAI ---
OPENAI_API_KEY=sk...
# Model with computer-use support (verify against your account + live docs).
CUA_MODEL=gpt-5.5
# OPTIONAL explicit override of the computer-use `environment`. Leave UNSET to
# derive it per channel automatically: web -> "browser", thick -> "ubuntu".
# Valid values: browser | ubuntu | windows | mac
# CUA_ENVIRONMENT=

# --- Murex environments ---
# For the web channel these are browser URLs; for the thick channel they are the
# env target passed into the container as $MUREX_ENV_TARGET.
MUREX_BEFORE_URL=https://murex-before.example.internal
MUREX_AFTER_URL=https://murex-after.example.internal
MUREX_USER=your_user
MUREX_PASS=your_password
# Login group / desk / entity context selected after authenticating. Scoped per
# ENVIRONMENT (same for every trade in that env). Global default + optional
# before/after overrides.
MUREX_LOGIN_GROUP=ACCT_DESK_01
# MUREX_BEFORE_GROUP=ACCT_DESK_01
# MUREX_AFTER_GROUP=ACCT_DESK_01
# Let the computer-use MODEL perform login (types MUREX_USER/MUREX_PASS) and
# pick the group itself, once per trade session, on BOTH channels. REQUIRED for
# the thick channel (its login cannot be scripted); optional for web. WARNING:
# this exposes the credentials to the model context and to every screenshot — it
# breaks the "credentials stay out of LLM context" invariant. Leave false to
# keep the deterministic logins (web: murex/login.py; thick: container entrypoint).
MUREX_LLM_LOGIN=true

# --- Access channel ---
# How to reach Murex: "web" (Playwright/Chromium) or "thick" (Murex Java client
# in a Linux Docker container, one container per trade).
MUREX_CHANNEL=thick
# Optional per-environment overrides (mix channels, e.g. before=web, after=thick).
# MUREX_BEFORE_CHANNEL=web
# MUREX_AFTER_CHANNEL=thick

# --- Thick-client (Docker) channel ---
# Required only when a channel above is "thick". The image must boot an X server
# on $DISPLAY at $SCREEN_GEOMETRY, launch the Murex client against
# $MUREX_ENV_TARGET, ship ImageMagick `import` and `xdotool`, and write exports
# to $MUREX_CONTAINER_EXPORT_DIR. Login depends on MUREX_LLM_LOGIN: when false
# the entrypoint logs in with $MUREX_USER/$MUREX_PASS; when true it leaves the
# client at the login screen for the model (creds are NOT passed to the container).
# Build the image first:  docker build -f docker/Dockerfile.thick -t murex-thick:latest .
# MUREX_DOCKER_IMAGE=murex-thick:latest
MUREX_DISPLAY=:99
MUREX_CONTAINER_EXPORT_DIR=/exports
# Boot readiness is PROBED, not slept: after `docker run` the harness waits for
# the Murex client window (WM_CLASS below) to appear, then for the screen to stop
# changing — returning the instant the login/app screen is painted. The settings
# below only bound/tune that probe.
# Hard cap on the wait (seconds); on timeout the harness proceeds anyway. 0 = skip
# the probe (don't wait at all).
MUREX_CONTAINER_READY_SECS=90
# Poll interval (seconds) for both probe phases.
# MUREX_CONTAINER_READY_POLL_SECS=2.0
# Consecutive identical screen signatures that mark "done painting".
# MUREX_CONTAINER_READY_STABLE_POLLS=2
# WM_CLASS substring identifying the client window (title carries the env IP, so
# the class is the stable, env-independent readiness key).
# MUREX_LOGIN_WINDOW_CLASS=murex-rmi-loader
# Per-container cgroup caps (docker run --cpus / --memory). Empty = no limit.
# Defaults bound each trade's container to 1 CPU / 512MB.
MUREX_DOCKER_CPUS=1
MUREX_DOCKER_MEMORY=512m
# Extra args spliced into `docker run` (comma-separated).
# MUREX_DOCKER_RUN_EXTRA=--shm-size=2g

# --- Run tuning ---
# Parallel trades. Web: one browser context each; thick: one container each.
MAX_CONCURRENCY=4
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=800
# Web-channel browser headless toggle (no effect on the thick channel).
HEADLESS=true
# Chromium V8 heap cap in MB (per renderer). Contexts share one browser process,
# so this is browser-wide, not per-session; CPU can't be capped via Playwright.
# 0 / unset = no cap.
PLAYWRIGHT_MAX_MEMORY_MB=512
MAX_TURNS=60
OUTPUT_DIR=data/out

# --- Diff config (confirm against the real Murex CSV schema) ---
# Comma-separated columns that uniquely identify an accounting posting.
DIFF_JOIN_COLUMNS=trade_id,gl_account,currency
# Absolute tolerance on numeric amount columns.
DIFF_ABS_TOL=0.01
DIFF_REL_TOL=0.0
