# Copy to .env and fill in. NEVER commit .env (gitignored).

# --- Model provider (computer-use) ---
# Which API drives the computer-use loop:
#   openai        -> OpenAI Responses API (default)
#   anthropic     -> direct Anthropic Messages API
#   bedrock       -> Anthropic Messages API over AWS Bedrock
#   bedrock-openai -> a GPT model on AWS Bedrock (OpenAI-compatible "mantle" Responses
#                     endpoint). No native computer tool there → computer-use is
#                     EMULATED with a custom function tool. NOTE: GPT is not GUI-
#                     grounding-fine-tuned, so expect more mis-clicks than Opus 4.8.
CUA_PROVIDER=openai
# Computer-use model id (provider-specific):
#   openai        -> e.g. gpt-5.5
#   anthropic     -> e.g. claude-opus-4-8
#   bedrock       -> an inference-profile id, e.g. eu.anthropic.claude-opus-4-8
#   bedrock-openai -> a Bedrock OpenAI model id, e.g. openai.gpt-5.5
CUA_MODEL=gpt-5.5
# Completion-token budget per turn (Anthropic REQUIRES it; ignored by OpenAI).
CUA_MAX_TOKENS=4096
# Reasoning effort for ANY provider. Unset = provider default (nothing sent).
# Values: none|minimal|low|medium|high|xhigh|max (availability is model-specific;
# the API validates). OpenAI -> reasoning.effort. Anthropic/Bedrock newest models
# (Opus 4.8/4.7/4.6, Sonnet 4.6) -> adaptive thinking + output_config.effort; older
# (Sonnet 4.5) -> extended-thinking budget_tokens. xhigh = Opus only; max =
# Sonnet 4.6+/Opus. For high/xhigh/max, raise CUA_MAX_TOKENS (thinking needs room).
# CUA_REASONING_EFFORT=high

# --- OpenAI (required when CUA_PROVIDER=openai) ---
OPENAI_API_KEY=sk...
# OPTIONAL explicit override of the OpenAI computer-use `environment`. Leave UNSET
# to derive it per channel automatically: web -> "browser", thick -> "ubuntu".
# Valid values: browser | ubuntu | windows | mac. OpenAI-only.
# CUA_ENVIRONMENT=

# --- Anthropic (direct) (required when CUA_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- AWS Bedrock (required when CUA_PROVIDER=bedrock) ---
# Auth is via a Bedrock API key (bearer token) — NO AWS access key/secret needed.
# AsyncAnthropicBedrock sends it as `Authorization: Bearer` and skips SigV4.
# AWS_REGION=eu-west-1
# AWS_BEARER_TOKEN_BEDROCK=ABSK...

# --- AWS Bedrock + OpenAI (GPT) (required when CUA_PROVIDER=bedrock-openai) ---
# Reuses AWS_BEARER_TOKEN_BEDROCK above (the OpenAI SDK sends it as Authorization:
# Bearer). Set CUA_MODEL=openai.gpt-5.5 and point CUA_OPENAI_BASE_URL at the mantle
# Responses endpoint for the GPT region (GPT-5.5 is in us-east-2). The SDK appends
# "/responses". AWS_REGION is not used by this provider (the region is in the URL).
# CUA_OPENAI_BASE_URL=https://bedrock-mantle.us-east-2.api.aws/openai/v1
# Prompt-cache retention (bedrock-openai only). GPT-5.5 caching is OFF unless this is
# sent (the backend also sends a stable prompt_cache_key). "in_memory" (default),
# "24h" (flaked), or empty (off). NOTE: in real runs caching barely hits (~1.5% of
# turns) — mantle's in_memory cache is engine-node-local and routing scatters each
# (seconds-apart) request to a cold node, so the warm cache evaporates. Kept because
# it's harmless and may pay off if routing stabilizes / for OpenAI-direct GPT. Real
# cost lever is CUA_KEEP_LAST_SCREENSHOTS (fewer/smaller screenshots); mantle bills
# ~full input every turn. Mantle also has NO native computer tool and flakes ~25%
# under load with a transient job-registration 400 — the backend retries in-session.
# CUA_OPENAI_PROMPT_CACHE_RETENTION=in_memory

# --- Anthropic computer-use tool generation (anthropic + bedrock) ---
# Defaults target the newest models (Opus 4.8/4.7/4.6, Sonnet 4.6). Override the
# PAIR for older models — e.g. Bedrock Sonnet 4.5 needs the 2025-01-24 generation.
# CUA_ANTHROPIC_TOOL_VERSION=computer_20251124
# CUA_ANTHROPIC_BETA=computer-use-2025-11-24
# How many recent screenshots to keep in history to bound token cost (0 = all).
# CUA_KEEP_LAST_SCREENSHOTS=3
# Prompt caching (anthropic + bedrock; default on). Inserts cache_control
# breakpoints so the byte-stable prefix bills at the 0.1x cache-read rate after
# turn 1 (5-min ephemeral cache). OpenAI caches automatically, so this is a no-op
# there. Raising CUA_KEEP_LAST_SCREENSHOTS enlarges the cacheable prefix (less
# pruning churn → bigger cache reads, at the cost of more retained image tokens).
# CUA_PROMPT_CACHE=true
# Max automatic SDK retries per request (exponential backoff), any provider. Covers
# transient 429/5xx — notably Bedrock 503 "unable to process your request" (on-demand
# capacity/throttle dips, common on Opus inference profiles). Retrying here rides out
# a blip without losing in-session progress. SDK default is 2; this raises it to 8.
# CUA_MAX_RETRIES=8

# --- Murex environments ---
# For the web channel these are browser URLs; for the thick channel they are the
# env target passed into the container as $MUREX_ENV_TARGET.
MUREX_BEFORE_URL=https://murex-before.example.internal
MUREX_AFTER_URL=https://murex-after.example.internal
MUREX_USER=your_user
MUREX_PASS=your_password
# Login group / desk / entity context selected after authenticating. Scoped per
# ENVIRONMENT (same for every trade in that env). Global default + optional
# before/after overrides.
MUREX_LOGIN_GROUP=ACCT_DESK_01
# MUREX_BEFORE_GROUP=ACCT_DESK_01
# MUREX_AFTER_GROUP=ACCT_DESK_01
# Let the computer-use MODEL perform login (types MUREX_USER/MUREX_PASS) and
# pick the group itself, once per trade session, on BOTH channels. REQUIRED for
# the thick channel (its login cannot be scripted); optional for web. WARNING:
# this exposes the credentials to the model context and to every screenshot — it
# breaks the "credentials stay out of LLM context" invariant. Leave false to
# keep the deterministic logins (web: murex/login.py; thick: container entrypoint).
MUREX_LLM_LOGIN=true

# --- Access channel ---
# How to reach Murex: "web" (Playwright/Chromium) or "thick" (Murex Java client
# in a Linux Docker container, one container per trade).
MUREX_CHANNEL=thick
# Optional per-environment overrides (mix channels, e.g. before=web, after=thick).
# MUREX_BEFORE_CHANNEL=web
# MUREX_AFTER_CHANNEL=thick

# --- Thick-client (Docker) channel ---
# Required only when a channel above is "thick". The image must boot an X server
# on $DISPLAY at $SCREEN_GEOMETRY, launch the Murex client against
# $MUREX_ENV_TARGET, ship ImageMagick `import` and `xdotool`, and write exports
# to $MUREX_CONTAINER_EXPORT_DIR. Login depends on MUREX_LLM_LOGIN: when false
# the entrypoint logs in with $MUREX_USER/$MUREX_PASS; when true it leaves the
# client at the login screen for the model (creds are NOT passed to the container).
# Build the image first:  docker build -f docker/Dockerfile.thick -t murex-thick:latest .
# MUREX_DOCKER_IMAGE=murex-thick:latest
MUREX_DISPLAY=:99
MUREX_CONTAINER_EXPORT_DIR=/exports
# Boot readiness is PROBED, not slept: after `docker run` the harness waits for
# the Murex client window (WM_CLASS below) to appear, then for the screen to stop
# changing — returning the instant the login/app screen is painted. The settings
# below only bound/tune that probe.
# Hard cap on the wait (seconds); on timeout the harness proceeds anyway. 0 = skip
# the probe (don't wait at all).
MUREX_CONTAINER_READY_SECS=90
# Poll interval (seconds) for both probe phases.
# MUREX_CONTAINER_READY_POLL_SECS=2.0
# Consecutive identical screen signatures that mark "done painting".
# MUREX_CONTAINER_READY_STABLE_POLLS=2
# WM_CLASS substring identifying the client window (title carries the env IP, so
# the class is the stable, env-independent readiness key).
# MUREX_LOGIN_WINDOW_CLASS=murex-rmi-loader
# Graceful Murex logout on teardown. The backend caps sessions PER USER and reaps a
# session only when its client disconnects; a hard kill can leave it lingering, so
# rapid retries/relaunches pile up and trip the cap. `docker stop -t <secs>` gives a
# SIGTERM-trapping client time to log out before SIGKILL.
# MUREX_CONTAINER_STOP_TIMEOUT_SECS=10
# Optional shell command run inside the container just before stop, to force a clean
# logout/disconnect when the client does NOT exit on SIGTERM (e.g. JVM not PID 1).
# Best-effort, time-bounded. Empty = skip. Example: "pkill -TERM java".
# MUREX_CONTAINER_LOGOUT_CMD=
# Per-container cgroup caps (docker run --cpus / --memory). Empty = no limit.
# Defaults bound each trade's container to 1 CPU / 512MB.
MUREX_DOCKER_CPUS=1
MUREX_DOCKER_MEMORY=512m
# Extra args spliced into `docker run` (comma-separated).
# MUREX_DOCKER_RUN_EXTRA=--shm-size=2g

# --- Run tuning ---
# Parallel trades. Web: one browser context each; thick: one container each.
MAX_CONCURRENCY=4
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=800
# Web-channel browser headless toggle (no effect on the thick channel).
HEADLESS=true
# Web channel only: ignore TLS cert errors in Chromium. On-prem Murex web servers
# usually present a self-signed / internal-CA cert, which otherwise aborts
# navigation with ERR_CERT_AUTHORITY_INVALID. Default true; set false only when the
# server has a publicly trusted certificate.
MUREX_IGNORE_HTTPS_ERRORS=true
# Web-channel interaction fidelity (no effect on the thick channel). The MX.3 web
# SPA animates menus/dropdowns and uses custom comboboxes, so a synthetic click
# needs a mousedown->mouseup gap to register, and the page needs a beat to repaint
# before the agent loop screenshots — else the model sees a stale frame and
# mis-clicks (dropdown selections not taking, typed text not landing). Both in ms;
# 0 disables. Raise CUA_WEB_SETTLE_MS if the UI is sluggish.
CUA_WEB_CLICK_DELAY_MS=60
CUA_WEB_SETTLE_MS=400
# Chromium V8 heap cap in MB (per renderer). Contexts share one browser process,
# so this is browser-wide, not per-session; CPU can't be capped via Playwright.
# 0 / unset = no cap.
PLAYWRIGHT_MAX_MEMORY_MB=512
MAX_TURNS=60
# Turn budget for the SECOND, log-off-only computer-use phase. After the export
# is collected and the reality gate passes (or fails), the model is re-driven on
# the same session to LOG OFF Murex cleanly so the per-user session cap (~6) isn't
# hit by the next trade. Small by design; best-effort (a failed log-off never
# changes the result). 0 disables the log-off phase.
LOGOFF_MAX_TURNS=8
# Max seconds the model waits for the accounting-sim postings table to populate
# after 'Proceed' before treating a still-empty table as a zero-posting result
# and exporting the header-only CSV. Guidance fed to the model (not a hard timer
# — Python never sees the table). Rows appearing sooner export immediately, so a
# generous value only costs turns on genuinely empty sims. Tune to real latency.
SIM_RESULT_WAIT_SECS=45
OUTPUT_DIR=data/out

# --- Diff config (confirm against the real Murex CSV schema) ---
# RAW Murex export delimiter ("Download as CSV" — Murex emits SEMICOLON-separated;
# the Comment column is double-quoted around its embedded ';').
CSV_DELIMITER=;
# Comma-separated columns that uniquely identify an accounting posting.
DIFF_JOIN_COLUMNS=trade_id,gl_account,currency
# Absolute tolerance on numeric amount columns.
DIFF_ABS_TOL=0.01
DIFF_REL_TOL=0.0

# --- Export reality gate (anti-hallucination) ---
# Before a trade counts as done, the collected CSV must be a REAL, non-empty,
# parseable file whose every posting references THIS trade. The model's "DONE"
# text is never trusted. A failed check returns ok=False, which the worker's
# existing retry (3 attempts) re-drives.
# Max seconds to WAIT for the export to appear after the agent loop ends (the
# model's last action may trigger the download/file just as the loop returns).
# 0 = check once, no wait.
EXPORT_WAIT_SECS=20
# Poll interval while waiting for the file to appear / its size to settle.
# EXPORT_POLL_SECS=0.5
# Thick channel only: consecutive equal file sizes that mark "done writing".
# EXPORT_STABLE_POLLS=2
# Minimum DATA rows (excluding header) a valid export must contain. Default 0:
# a zero-posting accounting simulation is a LEGITIMATE result — Murex still
# exports the header row, so a header-only CSV is trusted as an empty outcome
# (empty-before vs empty-after => MATCH; empty vs non-empty => present/missing
# difference). Set to 1 only when every trade must have postings.
# EXPORT_MIN_ROWS=0
# Require every posting row to reference this trade (catches the model exporting
# the WRONG trade). Disable only if a real export omits the column below.
# EXPORT_REQUIRE_TRADE_ID=true
# Comma-separated export columns that may carry the queried trade ref; a row passes
# if its id matches ANY of them. The id lands in "Trade nb" for a normal trade but in
# "Origin Trade nb" for an origin/novated trade (whose "Trade nb" is the resolved
# trade). Matching either keeps the anti-hallucination guarantee without rejecting
# legitimate origin trades. CONFIRM the column names against a real export.
# EXPORT_TRADE_ID_COLUMN=Trade nb,Origin Trade nb
